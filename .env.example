DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_BASE_PATH=""
SIGNMEETING_UPLOAD_DIR="./uploads"

# Admin login credentials for the SignMeeting console.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="signmeeting"

# Secret used to sign the session cookie. Generate a strong random value in
# production, e.g. `openssl rand -base64 32`.
AUTH_SECRET="change-me-in-production"
