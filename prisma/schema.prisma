generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Meeting {
  id                         String             @id @default(cuid())
  meetingId                  String             @unique
  meetingProjectName         String
  meetingName                String
  meetingDate                String
  startTime                  String
  endTime                    String             @default("10:00")
  meetingLocation            String
  meetingType                MeetingType
  internalMeetingName        String             @default("Smarterware")
  externalMeetingName        String?
  externalParticipantGroupId Int?
  internalGroupImageFilename String?
  internalGroupImageMime     String?
  internalGroupImageSize     Int?
  internalGroupImagePath     String?
  externalGroupImageFilename String?
  externalGroupImageMime     String?
  externalGroupImageSize     Int?
  externalGroupImagePath     String?
  allowLateRegister          Boolean            @default(false)
  qrTokenInt                 String?            @unique
  qrTokenExt                 String?            @unique
  qrUrlInt                   String?
  qrUrlExt                   String?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  attendances                Attendance[]
  photos                     MeetingPhoto[]
  documents                  MeetingDocument[]
  changeLogs                 MeetingChangeLog[]
  externalParticipantGroup   ParticipantGroup?  @relation(fields: [externalParticipantGroupId], references: [groupId], onDelete: SetNull)

  @@index([externalParticipantGroupId])
}

model MeetingChangeLog {
  id          String   @id @default(cuid())
  meetingId   String
  changedBy   String
  changesJson String
  createdAt   DateTime @default(now())
  meeting     Meeting  @relation(fields: [meetingId], references: [meetingId], onDelete: Cascade)

  @@index([meetingId, createdAt])
}

model Attendance {
  id            String             @id @default(cuid())
  personNo      Int
  meetingId     String
  channel       AttendanceType
  intPid        Int?
  participantId Int?
  fname         String
  lname         String
  department    String
  position      String
  email         String?
  phone         String?
  signaturePath String?
  dedupeKey     String?
  timestamp     DateTime           @default(now())
  meeting       Meeting            @relation(fields: [meetingId], references: [meetingId], onDelete: Cascade)
  participant   ParticipantPerson? @relation(fields: [participantId], references: [participantId], onDelete: SetNull)

  @@unique([meetingId, personNo])
  @@unique([meetingId, dedupeKey])
  @@index([meetingId])
  @@index([participantId])
}

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model MeetingPhoto {
  id          String   @id @default(cuid())
  meetingId   String
  filename    String
  mimeType    String
  size        Int
  storagePath String?
  data        String?
  createdAt   DateTime @default(now())
  meeting     Meeting  @relation(fields: [meetingId], references: [meetingId], onDelete: Cascade)

  @@index([meetingId])
}

model MeetingDocument {
  id          String   @id @default(cuid())
  meetingId   String
  filename    String
  mimeType    String
  size        Int
  storagePath String
  createdAt   DateTime @default(now())
  meeting     Meeting  @relation(fields: [meetingId], references: [meetingId], onDelete: Cascade)

  @@index([meetingId, createdAt])
}

model InternalPerson {
  intPid     Int      @id @default(autoincrement())
  fname      String
  lname      String
  department String
  position   String
  email      String?
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ParticipantGroup {
  groupId   Int                 @id @default(autoincrement())
  name      String              @unique
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  people    ParticipantPerson[]
  meetings  Meeting[]
}

model ParticipantPerson {
  participantId Int              @id @default(autoincrement())
  groupId       Int
  fname         String
  lname         String
  position      String
  email         String?
  phone         String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  group         ParticipantGroup @relation(fields: [groupId], references: [groupId], onDelete: Cascade)
  attendances   Attendance[]

  @@index([groupId, isActive])
}

enum MeetingType {
  INTERNAL
  EXTERNAL
}

enum AttendanceType {
  INTERNAL
  EXTERNAL
}
